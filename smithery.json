{
  "name": "boltzgen-design",
  "version": "1.1.0",
  "description": "나노바디 디자인 자동화: 자연어 요구사항 → BoltzGen spec YAML → MSA API 제출 (업로드 → 검증 → 제출 → 상태 추적 → 아티팩트)",
  "author": "SungminKo-smko",
  "repository": "https://github.com/SungminKo-smko/boltzgen-skill",
  "skills": ["SKILL.md"],
  "install": {
    "type": "git",
    "url": "https://github.com/SungminKo-smko/boltzgen-skill",
    "target": "~/.claude/skills/boltzgen-design",
    "post_install": "bash setup.sh"
  },
  "requirements": {
    "python": ">=3.9",
    "packages": ["httpx>=0.27.0", "pyyaml>=6.0.2"]
  },
  "config": {
    "API_BASE_URL": {
      "description": "nanobody-designer MSA API 서버 주소",
      "required": true
    },
    "API_KEY": {
      "description": "x-api-key 인증 키",
      "required": true
    }
  }
}
